# ===========================================
# EcoPharma — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.

# Hostinger SMTP (for lead form email notifications)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Optional: override notification recipients
# LEAD_NOTIFY_EMAIL=
# CHECKOUT_NOTIFY_EMAIL=
# ONBOARDING_NOTIFY_EMAIL=

# Google Sheets
GOOGLE_SHEET_WEBHOOK_URL=
GOOGLE_SHEET_LIFETIME_WEBHOOK_URL=

# Dodo Payments
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_PRODUCT_ID=
NEXT_PUBLIC_DODO_MODE=test
NEXT_PUBLIC_SITE_URL=
